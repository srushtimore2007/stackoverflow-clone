# Database Configuration
MONGODB_URL=mongodb://localhost:27017/stackoverflow-clone
PORT=5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=30d

# LibreTranslate Configuration
LIBRETRANSLATE_URL=http://localhost:5001
LIBRETRANSLATE_API_KEY=

# ======================
# EMAIL CONFIGURATION
# ======================

# SendGrid Configuration (PRIMARY EMAIL SERVICE)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER_EMAIL=noreply@yourdomain.com

# Legacy Email Configuration (DO NOT USE - Kept for reference only)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password-here

# Vonage Configuration (for SMS OTP)
VONAGE_API_KEY=your-vonage-api-key-here
VONAGE_API_SECRET=your-vonage-api-secret-here
VONAGE_FROM_NUMBER=StackOverflow

# Google Cloud Translation API (optional)
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# AWS Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# SendGrid Configuration (PRIMARY EMAIL SERVICE)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER_EMAIL=noreply@yourdomain.com

# Razorpay Configuration (for payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Resend Configuration (alternative email service)
RESEND_API_KEY=your-resend-api-key

# Twilio Configuration (alternative SMS service)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Development/Production
NODE_ENV=development
